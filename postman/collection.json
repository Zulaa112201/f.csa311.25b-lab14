                    "name": "Error — Байхгүй нийтлэл (404)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/posts/999999",
                            "host": ["{{baseUrl}}"],
                            "path": ["posts", "999999"]
                        },
                        "description": "Байхгүй ID-р хайх — 404 буцаах ёстой (negative test)"
                    },
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// Pre-request: байхгүй ID-г тодорхойлох",
                                    "pm.environment.set('nonExistentId', 999999);",
                                    "console.log('Testing with non-existent ID:', 999999);"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 404 байх ёстой (negative test)', () => {",
                                    "  pm.response.to.have.status(404);",
                                    "});",
                                    "",
                                    "pm.test('Response 1 секундэд багтах ёстой', () => {",
                                    "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                                    "});",
                                    "",
                                    "pm.test('Response хоосон объект байх ёстой', () => {",
                                    "  const data = pm.response.json();",
                                    "  pm.expect(data).to.be.an('object');",
                                    "  // JSONPlaceholder {} буцаадаг — энэ нь зөв алдааны зам",
                                    "  pm.expect(Object.keys(data).length).to.eql(0);",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ]
}